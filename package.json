{
  "name": "ourclinic-browser-demo",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "postcss": "$postcss"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "next dev -p 4173",
    "build": "npm run build --workspace @ourclinic/contracts && next build",
    "start": "next start -p 4173",
    "lint": "next lint",
    "typecheck": "tsc --noEmit && npm run typecheck --workspace @ourclinic/local-data",
    "test": "vitest run",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test tests/e2e",
    "test:visual": "playwright test tests/visual",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build && npm run test:e2e && npm run test:visual"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ourclinic/contracts": "*",
    "@ourclinic/local-data": "*",
    "@radix-ui/react-popover": "^1.1.19",
    "framer-motion": "^12.42.2",
    "gsap": "3.12.5",
    "lucide-react": "^0.469.0",
    "next": "15.5.20",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-pageflip": "2.0.3",
    "react-qr-code": "2.0.15",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.20",
    "fake-indexeddb": "^6.0.1",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  }
}
